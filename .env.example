# Database Configuration (Neon PostgreSQL)
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# NMI Partner API Credentials
# Your NMI Partner ID (e.g., LaskowskiD3124)
NMI_PARTNER_ID=LaskowskiD3124
# Your NMI Merchant Boarding API Key
NMI_MERCHANT_BOARDING_KEY=your_merchant_boarding_key_here
# NMI Partner API URL (optional - defaults to production URL)
NMI_PARTNER_API_URL=https://secure.nmi.com/api/v1/boarding

# NMI Payment Processing Credentials
# Your NMI Transaction API Key (for processing payments)
NMI_API_KEY=your_nmi_transaction_api_key_here

# Stripe (Checkout Sessions — internal to SwipesBlue only)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Session Secret (generate a random string for production)
SESSION_SECRET=your_session_secret_here
